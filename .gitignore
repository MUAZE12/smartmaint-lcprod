# ============================================================
# CRITICAL — do NOT commit any of the below to a public GitHub repo.
# GitHub's per-file limit is 100 MB and its soft repo limit is 1 GB.
# Everything below is either a huge binary, a secret, or generated.
# ============================================================

# Huge bundled binaries (>100 MB, would break the push)
runtime/node.exe
runtime/**
public/models/**
*.exe
*.msi
*.dmg
SmartMaint*.exe*
installer/Output/**

# Publish artefacts + logs
smartmaint-restart.log
smartmaint-restart-bootstrap.log
smartmaint-restart.ps1
.restart-lock
version.txt
update-channel.txt
.update-tmp/

# Secrets — NEVER commit
# Broad patterns — the initial push was blocked by publish-secret.txt.txt
# (double extension slipped past the narrower `publish-secret.txt` pattern).
.env*
publish-secret*
*service-role*
*service_role*
*api-key*.txt*
smartmaint-api-key*
cron-secret*

# Playwright / test artefacts
/test-results/
/playwright-report/
/playwright/.cache/
/coverage/

# IDE
.vscode/
.idea/
*.swp

# OS
Thumbs.db
desktop.ini

